<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
    PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.congcong.algomentor.api.preference.mapper.UserAiPreferenceMapper">

  <resultMap id="UserAiPreferenceRowMap"
      type="org.congcong.algomentor.api.preference.mapper.model.UserAiPreferenceRow">
    <constructor>
      <arg column="user_id" javaType="java.lang.Long"/>
      <arg column="coach_style" javaType="string"/>
      <arg column="response_language" javaType="string"/>
      <arg column="created_at" javaType="java.time.Instant"/>
      <arg column="updated_at" javaType="java.time.Instant"/>
    </constructor>
  </resultMap>

  <sql id="UserAiPreferenceColumns">
    user_id,
    coach_style,
    response_language,
    created_at,
    updated_at
  </sql>

  <select id="findByUserId" resultMap="UserAiPreferenceRowMap">
    SELECT
      <include refid="UserAiPreferenceColumns"/>
    FROM user_ai_preference
    WHERE user_id = #{userId}
  </select>

  <select id="upsert" resultMap="UserAiPreferenceRowMap" affectData="true">
    INSERT INTO user_ai_preference (
      user_id,
      coach_style,
      response_language,
      created_at,
      updated_at
    )
    VALUES (
      #{userId},
      #{coachStyle},
      #{responseLanguage},
      NOW(),
      NOW()
    )
    ON CONFLICT (user_id) DO UPDATE
    SET coach_style = #{coachStyle},
        response_language = #{responseLanguage},
        updated_at = NOW()
    RETURNING
      <include refid="UserAiPreferenceColumns"/>
  </select>
</mapper>

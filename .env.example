# 公共入口端口，由本地反向代理监听。
PROXY_PORT=8080
# Java Spring Boot 实际监听端口。SERVER_PORT 保留给旧脚本兼容，优先使用 API_PORT。
API_PORT=18080
SERVER_PORT=18080
PROMETHEUS_HOST=localhost
PROMETHEUS_PORT=9090

POSTGRES_DB=algo_mentor
POSTGRES_USER=algo_mentor
POSTGRES_PASSWORD=algo_mentor_dev
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
AUTH_LOGIN_SUCCESS_URL=/
AUTH_LOGOUT_SUCCESS_URL=/
AUTH_SESSION_TIMEOUT=7d
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAME_SITE=Lax

AI_GATEWAY_DEFAULT_PROVIDER=openai
AI_GATEWAY_DEFAULT_MODEL=gpt-5.2
LEARNING_PLAN_DRAFT_SSE_TIMEOUT=6m

OPENAI_ENABLED=false
# 测试 key 占位说明：只有已吊销、无计费权限或无外部访问权限的测试 key，泄露后才不会产生实际影响。
# 真实 OpenAI key 不要提交到仓库，请在本机环境变量或未跟踪的本地配置中设置。
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5.2
OPENAI_TIMEOUT=30s
OPENAI_STREAM_TIMEOUT=5m
OPENAI_MAX_RETRIES=2

AGENT_CALCULATOR_TOOL_ENABLED=true
AGENT_TOOL_CHOICE=auto
AGENT_SPECIFIC_TOOL_NAME=
